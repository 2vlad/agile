# ─── Telegram ───────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_USER_IDS=123456789

# ─── LLM Provider ──────────────────────────────────────
# Supported: openai | anthropic | yandex | ollama
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=                # custom endpoint (optional)

# ─── Embedding Provider ────────────────────────────────
# Supported: openai | yandex | ollama
EMBED_PROVIDER=openai
# EMBED_API_KEY=               # defaults to LLM_API_KEY
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
# EMBED_BASE_URL=              # custom endpoint (optional)

# ─── Yandex Cloud (only when provider=yandex) ──────────
# YC_API_KEY=
# YC_FOLDER_ID=

# ─── Database ──────────────────────────────────────────
# For local docker-compose setup:
DATABASE_URL=postgresql://bot:bot@localhost:5432/bot
DB_STATEMENT_CACHE_SIZE=0
# DB_SSL_CA=                   # path to CA cert for managed DBs

# ─── Webhook ───────────────────────────────────────────
# Leave empty for polling mode (local dev)
WEBHOOK_URL=

# ─── Auto-index ────────────────────────────────────────
AUTO_INDEX=true
CORPUS_DIR=./corpus

# ─── Bot tuning ────────────────────────────────────────
HISTORY_MAX=20
HISTORY_TRIM_TO=16
HISTORY_TTL_SECONDS=3600
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
CONTEXT_RADIUS=5
MAX_SEARCH_RESULTS=20

# ─── Langfuse (optional) ───────────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
