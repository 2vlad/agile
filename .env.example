TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_USER_IDS=123456789,987654321

YC_API_KEY=your_yandex_cloud_api_key
YC_FOLDER_ID=your_yandex_folder_id
# Optional - defaults computed from YC_FOLDER_ID:
# YC_LLM_MODEL=
# YC_EMBED_DOC_MODEL=
# YC_EMBED_QUERY_MODEL=
# YC_LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
# YC_EMBEDDINGS_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding

DATABASE_URL=postgresql://user:password@localhost:5432/monograph_bot
# Production note: SSL handled via asyncpg ssl parameter, not DSN sslmode

CORPUS_DIR=./corpus
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
MAX_AGENT_ITERATIONS=4
CONTEXT_RADIUS=5
