# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_USER_IDS=123456789,987654321

# Yandex Cloud
YC_API_KEY=your_yandex_cloud_api_key
YC_FOLDER_ID=your_yandex_folder_id
# Optional — defaults computed from YC_FOLDER_ID if empty:
# YC_LLM_MODEL=
# YC_EMBED_DOC_MODEL=
# YC_EMBED_QUERY_MODEL=
# YC_LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
# YC_EMBEDDINGS_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding

# Database (asyncpg DSN)
DATABASE_URL=postgresql://user:password@host:6432/dbname?sslmode=require
# Set to 0 for PgBouncer compatibility
DB_STATEMENT_CACHE_SIZE=0

# Webhook (public HTTPS URL for Telegram webhook)
WEBHOOK_URL=https://your-domain.com

# Bot history settings
HISTORY_MAX=20
HISTORY_TRIM_TO=16
HISTORY_TTL_SECONDS=3600

# Langfuse (optional — tracing disabled if empty)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# App config
CORPUS_DIR=./corpus
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
MAX_AGENT_ITERATIONS=4
CONTEXT_RADIUS=5
MAX_SEARCH_RESULTS=20
